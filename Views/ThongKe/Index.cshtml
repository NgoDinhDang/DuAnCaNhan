@model STOREBOOKS.ViewModels.ThongKeDoanhThuViewModel

@{
    ViewData["Title"] = "Thống kê doanh thu";

    var labelsNgay = string.Join(",", Model.DoanhThuTheoNgayList.Select(x => $"'{x.Ngay.ToString("dd/MM")}'"));
    var dataNgay = string.Join(",", Model.DoanhThuTheoNgayList.Select(x => x.TongTien));

    var labelsThang = string.Join(",", Model.DoanhThuTheoThangList.Select(x => $"'Tháng {x.Thang}/{x.Nam}'"));
    var dataThang = string.Join(",", Model.DoanhThuTheoThangList.Select(x => x.TongTien));

    var labelsNam = string.Join(",", Model.DoanhThuTheoNamList.Select(x => $"'{x.Nam}'"));
    var dataNam = string.Join(",", Model.DoanhThuTheoNamList.Select(x => x.TongTien));
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-chart-line me-2"></i>
                Thống kê doanh thu
            </h2>
            <p class="admin-page-subtitle">Theo dõi và phân tích doanh thu của cửa hàng</p>
        </div>
    </div>
</div>

<partial name="_AdminNav" />

@if (TempData["ValidationMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ValidationMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label for="tuNgay" class="form-label">Từ ngày</label>
        <input type="date" class="form-control" name="tuNgay" value="@Model.TuNgay.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-3">
        <label for="denNgay" class="form-label">Đến ngày</label>
        <input type="date" class="form-control" name="denNgay" value="@Model.DenNgay.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn btn-primary w-100">Lọc</button>
    </div>
</form>

<div class="mb-4">
    <h4 class="text-success">Tổng doanh thu: @Model.TongDoanhThu.ToString("N0") VNĐ</h4>
</div>

<ul class="nav nav-tabs mb-3" id="thongKeTabs">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#ngay">Theo ngày</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#thang">Theo tháng</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#nam">Theo năm</a>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="ngay">
        <canvas id="chartNgay" height="100"></canvas>
    </div>
    <div class="tab-pane fade" id="thang">
        <canvas id="chartThang" height="100"></canvas>
    </div>
    <div class="tab-pane fade" id="nam">
        <canvas id="chartNam" height="100"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const formatMoney = (val) => val.toLocaleString('vi-VN') + ' đ';

        const createChart = (id, label, labels, data) => {
            new Chart(document.getElementById(id).getContext('2d'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: data,
                        borderColor: 'rgb(75, 192, 192)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return formatMoney(value);
                                }
                            }
                        }
                    }
                }
            });
        };

        createChart('chartNgay', 'Doanh thu theo ngày', [@Html.Raw(labelsNgay)], [@Html.Raw(dataNgay)]);
        createChart('chartThang', 'Doanh thu theo tháng', [@Html.Raw(labelsThang)], [@Html.Raw(dataThang)]);
        createChart('chartNam', 'Doanh thu theo năm', [@Html.Raw(labelsNam)], [@Html.Raw(dataNam)]);
    </script>
}
