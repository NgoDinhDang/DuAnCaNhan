    "/api/ApiAuth/Me": {
      "get": {
        "tags": [
          "ApiAuth"
        ],
        "summary": "Lấy thông tin user hiện tại từ JWT token",
        "description": "Yêu cầu header: Authorization: Bearer {token}",
        "responses": {
          "200": {
            "description": "Trả về thông tin user"
          },
          "401": {
            "description": "Token không hợp lệ hoặc hết hạn",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Không tìm thấy user",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
