@{
    ViewData["Title"] = "Quản lý Chat - Tư vấn khách hàng";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-comments me-2"></i>
                Quản lý Chat
            </h2>
            <p class="admin-page-subtitle">Tư vấn và hỗ trợ khách hàng trực tuyến</p>
        </div>
    </div>
</div>

<partial name="_AdminNav" />

<div class="chat-container">
    <div class="chat-sidebar">
        <!-- Header Sidebar -->
        <div class="chat-sidebar-header">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="searchChat" placeholder="Tìm kiếm cuộc trò chuyện..." />
            </div>
            <button class="btn-new-chat" title="Làm mới danh sách">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>

        <!-- Filter -->
        <div class="chat-filter">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="filterUnreadOnly" />
                <label class="form-check-label" for="filterUnreadOnly">
                    <i class="fas fa-envelope"></i> Chỉ hiện tin nhắn chưa đọc
                </label>
            </div>
        </div>

        <!-- Danh sách cuộc trò chuyện -->
        <div id="userList" class="conversation-list">
            <div id="noUser" class="no-conversation">
                <i class="fas fa-inbox"></i>
                <p>Chưa có cuộc trò chuyện nào</p>
            </div>
        </div>
    </div>

    <div class="chat-main">
        <!-- Header Chat -->
        <div class="chat-header">
            <div class="chat-header-info">
                <span class="chat-to-label">To:</span>
                <span id="chattingWithHeader" class="chat-to-name">Chọn khách hàng để chat</span>
            </div>
        </div>

        <!-- Nội dung chat -->
        <div id="chatBox" class="chat-content">
            <div id="chatDefaultMessage" class="chat-empty-state">
                <i class="fas fa-comments"></i>
                <p>Chọn một cuộc trò chuyện để bắt đầu</p>
            </div>
        </div>

        <!-- Input chat -->
        <div class="chat-input-wrapper">
            <input type="file" id="adminImageInput" accept="image/*" style="display: none;" />
            <button class="chat-input-btn" id="uploadAdminImage" type="button" title="Đính kèm file" disabled>
                <i class="fas fa-paperclip"></i>
            </button>
            <input type="text" id="adminMessageInput" class="chat-input" placeholder="Nhập tin nhắn..." disabled />
            <button class="chat-input-btn" id="btnEmoji" type="button" title="Emoji" disabled>
                <i class="far fa-smile"></i>
            </button>
            <button class="chat-send-btn" id="sendAdminMessage" type="button" disabled>
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        // === KHỞI TẠO ===
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("@Url.Content("~/chatHub")") // Dùng Url.Content để an toàn
            .build();

        // Data storage
        // Map này sẽ lưu trữ toàn bộ cuộc trò chuyện
        // Key: connectionId, Value: { userName, messages: [] }
        let conversations = new Map();
        let activeConnectionId = null; // ID của khách hàng đang được chọn

        // Lấy Element
        const userListEl = document.getElementById("userList");
        const chatBoxEl = document.getElementById("chatBox");
        const messageInputEl = document.getElementById("adminMessageInput");
        const sendButtonEl = document.getElementById("sendAdminMessage");
        const chattingWithHeaderEl = document.getElementById("chattingWithHeader");
        const noUserEl = document.getElementById("noUser");
        const chatDefaultMessageEl = document.getElementById("chatDefaultMessage");
        const uploadAdminImageBtn = document.getElementById("uploadAdminImage");
        const adminImageInput = document.getElementById("adminImageInput");

        // === LOGIC SIGNALR ===

        // 1. Nhận tin nhắn từ khách hàng
        connection.on("ReceiveCustomerMessage", function (user, message, time, connectionId) {
            console.log("ðŸ“¨ Nhận tin nhắn từ khách hàng:", { user, message, time, connectionId });

            let isNewUser = false;
            // Nếu khách hàng này chưa có trong Map, tạo mới
            if (!conversations.has(connectionId)) {
                conversations.set(connectionId, { userName: user, messages: [], unreadCount: 0 });
                isNewUser = true;
            }

            // Lưu tin nhắn vào Map
            const convo = conversations.get(connectionId);
            convo.messages.push({ sender: 'customer', message, time });

            // Tăng số lượng chưa đọc nếu không phải đang chat với khách này
            if (activeConnectionId !== connectionId) {
                convo.unreadCount = (convo.unreadCount || 0) + 1;
            }

            // Cập nhật danh sách UI (cột trái)
            updateUserListUI(connectionId, user, message, isNewUser, convo.unreadCount || 0);

            // Nếu admin đang chat với khách này, hiển thị tin nhắn ngay (cột phải)
            if (activeConnectionId === connectionId) {
                appendMessageToChatBox('customer', user, message, time);
                // Đánh dấu đã đọc ngay
                markConversationAsRead(connectionId);
            }

            playNotificationSound();
            saveMessageToDatabase(user, message, connectionId, false);
        });

        // Nhận hình ảnh từ khách hàng
        connection.on("ReceiveCustomerImage", function (user, imageUrl, time, connectionId) {
            console.log("📸 Nhận hình ảnh từ khách hàng:", { user, imageUrl, connectionId });

            let isNewUser = false;
            if (!conversations.has(connectionId)) {
                conversations.set(connectionId, { userName: user, messages: [], unreadCount: 0 });
                isNewUser = true;
            }

            const convo = conversations.get(connectionId);
            convo.messages.push({ sender: 'customer', message: `[IMAGE]${imageUrl}`, time });

            // Tăng số lượng chưa đọc nếu không phải đang chat với khách này
            if (activeConnectionId !== connectionId) {
                convo.unreadCount = (convo.unreadCount || 0) + 1;
            }

            updateUserListUI(connectionId, user, '📸 Đã gửi hình ảnh', isNewUser, convo.unreadCount || 0);

            if (activeConnectionId === connectionId) {
                appendImageToChatBox('customer', user, imageUrl, time);
                // Đánh dấu đã đọc ngay
                markConversationAsRead(connectionId);
            }

            playNotificationSound();
        });

        // 2. Nhận tin nhắn của chính admin (để xác nhận đã gửi)
        connection.on("ReceiveAdminOwnMessage", function (adminName, message, time, clientConnectionId) {
            if (conversations.has(clientConnectionId)) {
                // Lưu tin nhắn vào Map
                conversations.get(clientConnectionId).messages.push({ sender: 'admin', message, time });

                // Hiển thị nếu đang active (cột phải)
                if (activeConnectionId === clientConnectionId) {
                    appendMessageToChatBox('admin', 'Bạn (Admin)', message, time);
                }
            }
            saveMessageToDatabase(adminName, message, clientConnectionId, true);
        });

        // Nhận hình ảnh của chính admin
        connection.on("ReceiveAdminOwnImage", function (adminName, imageUrl, time, clientConnectionId) {
            if (conversations.has(clientConnectionId)) {
                conversations.get(clientConnectionId).messages.push({ sender: 'admin', message: `[IMAGE]${imageUrl}`, time });

                if (activeConnectionId === clientConnectionId) {
                    appendImageToChatBox('admin', 'Bạn (Admin)', imageUrl, time);
                }
            }
        });

        // 3. Khởi động kết nối
        connection.start().then(function () {
            console.log("âœ… SignalR Connected as Admin");
            return connection.invoke("JoinAdminGroup");
        }).then(function() {
            console.log("âœ… Admin đã join group 'Admins' thành công");
        }).catch(function (err) {
            console.error("âŒ Lỗi kết nối SignalR:", err.toString());
            alert("Không thể kết nối đến hệ thống chat. Vui lòng refresh trang.");
        });

        // === LOGIC GỬI TIN ===

        sendButtonEl.addEventListener("click", sendAdminMessage);
        messageInputEl.addEventListener("keypress", function (event) {
            if (event.key === "Enter") {
                event.preventDefault(); // Ngăn xuống dòng
                sendAdminMessage();
            }
        });

        // Upload image button
        if (uploadAdminImageBtn) {
            uploadAdminImageBtn.addEventListener("click", function() {
                if (!activeConnectionId) {
                    alert("Vui lòng chọn khách hàng trước!");
                    return;
                }
                adminImageInput.click();
            });
        }

        if (adminImageInput) {
            adminImageInput.addEventListener("change", function(e) {
                const file = e.target.files[0];
                if (file && activeConnectionId) {
                    uploadAdminImage(file);
                }
            });
        }

        function sendAdminMessage() {
            const message = messageInputEl.value;
            // Chỉ gửi khi có nội dung VÀ đã chọn khách hàng
            if (message.trim() === "" || !activeConnectionId) return;

            connection.invoke("SendAdminReply", activeConnectionId, "Nhân viên hỗ trợ", message)
                .then(function() {
                    messageInputEl.value = ""; // Xóa input sau khi gửi
                })
                .catch(function (err) {
                    console.error(err.toString());
                    alert('Không thể gửi tin nhắn. Khách hàng có thể đã ngắt kết nối.');
                });
        }

        // === LOGIC QUẢN LÝ UI ===

        // Cập nhật danh sách khách hàng (cột trái)
        function updateUserListUI(connectionId, userName, lastMessage, isNew, unreadCount = 0) {
            if (noUserEl) {
                noUserEl.style.display = 'none'; // Ẩn thông báo "chưa có khách"
            }

            let userEl = document.getElementById(`user-${connectionId}`);
            const wasExisting = !!userEl; // Kiểm tra xem đã tồn tại chưa

            // Nếu là khách mới, tạo element mới
            if (!userEl) {
                userEl = document.createElement("div");
                userEl.id = `user-${connectionId}`;
                userEl.className = "conversation-item";
                // Khi click vào user, gọi hàm selectUser
                userEl.onclick = () => selectUser(connectionId);
            }

            const hasUnread = unreadCount > 0;
            const firstLetter = userName.charAt(0).toUpperCase();
            const currentTime = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

            userEl.innerHTML = `
                <div class="conversation-avatar">${escapeHtml(firstLetter)}</div>
                <div class="conversation-info">
                    <div class="conversation-header">
                        <span class="conversation-name">${escapeHtml(userName)}</span>
                        <span class="conversation-time">${currentTime}</span>
                    </div>
                    <div class="conversation-preview">${escapeHtml(lastMessage)}</div>
                </div>
                ${hasUnread ? `<span class="unread-badge">${unreadCount}</span>` : ''}
            `;

            // Đặt attribute để filter
            userEl.setAttribute('data-unread-count', unreadCount);

            // CHỈ prepend nếu là conversation mới, nếu đã tồn tại thì chỉ cập nhật nội dung
            if (!wasExisting) {
                // Đưa khách hàng mới lên đầu danh sách
                userListEl.prepend(userEl);
            } else {
                // Nếu đã tồn tại, chỉ cập nhật nội dung và đưa lên đầu nếu có tin nhắn mới
                if (hasUnread || lastMessage) {
                    // Di chuyển lên đầu danh sách
                    userEl.remove();
                    userListEl.prepend(userEl);
                }
            }
        }

        // Chọn một khách hàng để chat
        function selectUser(connectionId) {
            if (activeConnectionId === connectionId) return; // Không cần làm gì nếu đã chọn

            activeConnectionId = connectionId; // Đặt khách hàng này làm active
            const convo = conversations.get(connectionId);

            // Đánh dấu tất cả tin nhắn của cuộc hội thoại này đã đọc
            markConversationAsRead(connectionId);

            // Xóa highlight ở các user khác
            document.querySelectorAll('.conversation-item').forEach(el => {
                el.classList.remove('active');

                // Xóa tag "Mới" và unread styling khi được click
                if (el.id === `user-${connectionId}`) {
                    el.classList.add('active'); // Highlight user được chọn
                    const badge = el.querySelector('.unread-badge');
                    if (badge) badge.remove();
                    el.setAttribute('data-unread-count', '0');
                }
            });

            // Cập nhật header
            chattingWithHeaderEl.textContent = convo.userName;

            // Kích hoạt input và upload button
            messageInputEl.disabled = false;
            sendButtonEl.disabled = false;
            uploadAdminImageBtn.disabled = false;
            const btnEmoji = document.getElementById('btnEmoji');
            if (btnEmoji) btnEmoji.disabled = false;
            messageInputEl.placeholder = `Nhập tin nhắn...`;
            messageInputEl.focus();

            // Xóa khung chat cũ và hiển thị loading
            chatBoxEl.innerHTML = `
                <div class="loading-container">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Đang tải lịch sử chat...</p>
                </div>
            `;

            // Load TẤT CẢ lịch sử từ database
            loadFullChatHistory(connectionId, convo.userName);
        }

        // Load toàn bộ lịch sử chat từ database cho một khách hàng
        function loadFullChatHistory(connectionId, userName) {
            fetch(`/Chat/GetChatHistory?connectionId=${encodeURIComponent(connectionId)}&limit=1000`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log(`📚 Đã load ${data.messages?.length || 0} tin nhắn từ database cho ${userName}`);
                    
                    // Xóa khung chat
                    chatBoxEl.innerHTML = "";

                    if (data.success && data.messages && data.messages.length > 0) {
                        // Cập nhật lại messages trong Map
                        if (conversations.has(connectionId)) {
                            const convo = conversations.get(connectionId);
                            convo.messages = [];
                            
                            data.messages.forEach(msg => {
                                const sender = msg.isAdminMessage ? 'admin' : 'customer';
                                const msgData = {
                                    sender: sender,
                                    message: msg.messageType === 'image' && msg.imageUrl ? `[IMAGE]${msg.imageUrl}` : msg.message,
                                    time: msg.sentAt
                                };
                                convo.messages.push(msgData);
                            });
                        }

                        // Hiển thị tất cả tin nhắn
                        data.messages.forEach(msg => {
                            const name = msg.isAdminMessage ? 'Bạn (Admin)' : userName;
                            
                            if (msg.messageType === 'image' && msg.imageUrl) {
                                appendImageToChatBox(
                                    msg.isAdminMessage ? 'admin' : 'customer',
                                    name,
                                    msg.imageUrl,
                                    msg.sentAt
                                );
                            } else {
                                appendMessageToChatBox(
                                    msg.isAdminMessage ? 'admin' : 'customer',
                                    name,
                                    msg.message,
                                    msg.sentAt
                                );
                            }
                        });

                        // Cuộn xuống tin nhắn mới nhất
                        setTimeout(() => {
                            chatBoxEl.scrollTop = chatBoxEl.scrollHeight;
                        }, 100);
                    } else {
                        // Không có tin nhắn
                        chatBoxEl.innerHTML = `
                            <div class="chat-empty-state">
                                <i class="fas fa-comments"></i>
                                <p>Chưa có tin nhắn nào với ${escapeHtml(userName)}</p>
                            </div>
                        `;
                    }
                })
                .catch(error => {
                    console.error('❌ Lỗi load lịch sử chat:', error);
                    chatBoxEl.innerHTML = `
                        <div class="chat-empty-state" style="color: #ff4444;">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>Không thể tải lịch sử chat</p>
                            <button class="btn btn-primary btn-sm mt-3" onclick="loadFullChatHistory('${connectionId}', '${escapeHtml(userName)}')">
                                <i class="fas fa-redo"></i> Thử lại
                            </button>
                        </div>
                    `;
                });
        }

        // Thêm 1 tin nhắn vào khung chat (cột phải)
        function appendMessageToChatBox(senderType, user, message, time) {
            if (chatDefaultMessageEl) {
                chatDefaultMessageEl.style.display = 'none'; // Ẩn tin nhắn chào mừng
            }

            const messageWrapper = document.createElement("div");
            messageWrapper.className = `message-wrapper ${senderType === 'admin' ? 'sent' : 'received'}`;

            const messageBubble = document.createElement("div");
            messageBubble.className = "message-bubble";

            // Nếu là tin nhắn từ khách hàng, hiển thị tên người gửi
            if (senderType !== 'admin') {
                const senderSpan = document.createElement("span");
                senderSpan.className = "message-sender";
                senderSpan.textContent = user;
                messageBubble.appendChild(senderSpan);
            }

            // Nội dung tin nhắn
            const messageText = document.createElement("div");
            messageText.textContent = message;
            messageBubble.appendChild(messageText);

            // Thời gian
            const timeSpan = document.createElement("span");
            timeSpan.className = "message-time";
            timeSpan.textContent = time;
            messageBubble.appendChild(timeSpan);

            messageWrapper.appendChild(messageBubble);
            chatBoxEl.appendChild(messageWrapper);
            chatBoxEl.scrollTop = chatBoxEl.scrollHeight; // Tự động cuộn xuống
        }

        // Thêm hình ảnh vào khung chat
        function appendImageToChatBox(senderType, user, imageUrl, time) {
            if (chatDefaultMessageEl) {
                chatDefaultMessageEl.style.display = 'none';
            }

            const messageWrapper = document.createElement("div");
            messageWrapper.className = `message-wrapper ${senderType === 'admin' ? 'sent' : 'received'}`;

            const messageBubble = document.createElement("div");
            messageBubble.className = "message-bubble";

            // Nếu là tin nhắn từ khách hàng, hiển thị tên người gửi
            if (senderType !== 'admin') {
                const senderSpan = document.createElement("span");
                senderSpan.className = "message-sender";
                senderSpan.textContent = user;
                messageBubble.appendChild(senderSpan);
            }

            // Hình ảnh
            const img = document.createElement("img");
            img.src = imageUrl;
            img.className = "message-image";
            img.alt = "Image";
            img.onclick = () => window.open(imageUrl, '_blank');
            messageBubble.appendChild(img);

            // Thời gian
            const timeSpan = document.createElement("span");
            timeSpan.className = "message-time";
            timeSpan.textContent = time;
            messageBubble.appendChild(timeSpan);

            messageWrapper.appendChild(messageBubble);
            chatBoxEl.appendChild(messageWrapper);
            chatBoxEl.scrollTop = chatBoxEl.scrollHeight;
        }

        // Upload admin image
        function uploadAdminImage(file) {
            if (file.size > 5 * 1024 * 1024) {
                alert('Kích thước file không được vượt quá 5MB!');
                return;
            }

            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                alert('Chỉ chấp nhận file ảnh (JPG, PNG, GIF, WEBP)!');
                return;
            }

            // Show loading
            const loadingDiv = document.createElement("div");
            loadingDiv.className = "message-wrapper sent";
            loadingDiv.innerHTML = `
                <div class="message-bubble">
                    <i class="fas fa-spinner fa-spin"></i> Đang tải ảnh lên...
                </div>
            `;
            chatBoxEl.appendChild(loadingDiv);

            const formData = new FormData();
            formData.append('file', file);
            formData.append('senderName', 'Admin');
            formData.append('connectionId', activeConnectionId);
            formData.append('isAdminMessage', true);
            formData.append('maNguoiDung', null);

            fetch('/Chat/UploadChatImage', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(err => {
                        throw new Error(err.error || 'Upload thất bại');
                    });
                }
                return response.json();
            })
            .then(data => {
                loadingDiv.remove();

                if (data.success) {
                    // Send image via SignalR
                    connection.invoke("SendAdminImage", activeConnectionId, "Nhân viên hỗ trợ", data.imageUrl)
                        .then(() => {
                            console.log('✅ Đã gửi hình ảnh');
                        })
                        .catch(err => {
                            console.error('❌ Lỗi gửi hình ảnh:', err);
                        });
                } else {
                    alert(data.error || 'Upload thất bại');
                }

                adminImageInput.value = '';
            })
            .catch(error => {
                loadingDiv.remove();
                console.error('❌ Error uploading image:', error);
                alert('Lỗi: ' + error.message);
                adminImageInput.value = '';
            });
        }

        // === HÀM HỖ TRỢ ===

        function playNotificationSound() {
            try {
                const audio = new Audio('data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQoGAACBhYqFbF1fdJivrJBhNjVgodDbq2EcBj+a2/LDciUFLIHO8tiJNwgZaLvt559NEAxQp+PwtmMcBjiR1/LMeSwFJHfH8N2QQAoUXrTp66hVFApGn+DyvmwhBSuBzvLaiTYIGGe77OegTQ==');
                audio.play();
            } catch (e) {
                // Ignore
            }
        }

        function escapeHtml(text) {
            if (!text) return "";
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        function saveMessageToDatabase(senderName, message, connectionId, isAdminMessage) {
            fetch('/Chat/SaveMessage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    senderName: senderName,
                    message: message,
                    connectionId: connectionId,
                    isAdminMessage: isAdminMessage,
                    maNguoiDung: @(Context.Session.GetInt32("MaNguoiDung")?.ToString() ?? "null")
                })
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(err => {
                        console.error('❌ Lỗi lưu tin nhắn:', err);
                        throw new Error(err.error || 'Không thể lưu tin nhắn');
                    });
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    console.log('✅ Đã lưu tin nhắn vào database. ID:', data.id);
                }
            })
            .catch(error => {
                console.error('❌ Error saving message:', error);
            });
        }

        // Đánh dấu cuộc hội thoại đã đọc
        function markConversationAsRead(connectionId) {
            // Reset unread count trong conversations Map
            if (conversations.has(connectionId)) {
                conversations.get(connectionId).unreadCount = 0;
            }

            fetch('/Chat/MarkConversationAsRead?connectionId=' + encodeURIComponent(connectionId), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log(`✅ Đã đánh dấu ${data.markedCount} tin nhắn là đã đọc cho connectionId: ${connectionId}`);
                }
            })
            .catch(error => {
                console.error('❌ Lỗi đánh dấu đã đọc:', error);
            });
        }

        // Xử lý filter chỉ hiện chưa đọc
        const filterUnreadCheckbox = document.getElementById('filterUnreadOnly');
        filterUnreadCheckbox.addEventListener('change', function() {
            const showOnlyUnread = this.checked;
            const allUsers = document.querySelectorAll('.conversation-item');
            
            allUsers.forEach(userEl => {
                const unreadCount = parseInt(userEl.getAttribute('data-unread-count') || '0');
                
                if (showOnlyUnread) {
                    // Chỉ hiện users có tin nhắn chưa đọc
                    if (unreadCount > 0) {
                        userEl.style.display = '';
                    } else {
                        userEl.style.display = 'none';
                    }
                } else {
                    // Hiện tất cả
                    userEl.style.display = '';
                }
            });

            // Kiểm tra nếu không còn user nào hiện thị
            const visibleUsers = Array.from(allUsers).filter(el => el.style.display !== 'none');
            if (visibleUsers.length === 0 && noUserEl) {
                noUserEl.style.display = 'flex';
                noUserEl.querySelector('p').textContent = showOnlyUnread ? 
                    'Không có tin nhắn chưa đọc' : 'Chưa có cuộc trò chuyện nào';
            } else if (noUserEl) {
                noUserEl.style.display = 'none';
            }
        });

        // Xử lý tìm kiếm
        const searchInput = document.getElementById('searchChat');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                const allUsers = document.querySelectorAll('.conversation-item');
                
                allUsers.forEach(userEl => {
                    const userName = userEl.querySelector('.conversation-name')?.textContent.toLowerCase() || '';
                    const preview = userEl.querySelector('.conversation-preview')?.textContent.toLowerCase() || '';
                    
                    if (userName.includes(searchTerm) || preview.includes(searchTerm)) {
                        userEl.style.display = '';
                    } else {
                        userEl.style.display = 'none';
                    }
                });
            });
        }

        // Xử lý nút refresh
        const btnRefresh = document.querySelector('.btn-new-chat');
        if (btnRefresh) {
            btnRefresh.addEventListener('click', function() {
                location.reload();
            });
        }

    </script>

