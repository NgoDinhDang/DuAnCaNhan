@model STOREBOOKS.Models.Payment
@{
    ViewData["Title"] = $"Thanh toán #{Model.PaymentId}";
    var order = Model.Order;
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-credit-card me-2"></i>
                Chi tiết thanh toán #@Model.PaymentId
            </h2>
            <p class="admin-page-subtitle">Đơn hàng #@Model.OrderId · @Model.PaymentMethod</p>
        </div>
        <a asp-area="Admin" asp-controller="AdminPayment" asp-action="Index" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Số tiền</p>
                <h4 class="fw-bold text-success">@Model.Amount.ToString("N0") đ</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Trạng thái</p>
                <span class="badge bg-primary">@Model.Status</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Ngày tạo</p>
                <h5 class="fw-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</h5>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Ngày thanh toán</p>
                <h5 class="fw-semibold">
                    @(Model.PaymentDate == default ? "Chưa cập nhật" : Model.PaymentDate.ToString("dd/MM/yyyy HH:mm"))
                </h5>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Thông tin giao dịch</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Phương thức</dt>
                    <dd class="col-sm-7">@Model.PaymentMethod</dd>

                    <dt class="col-sm-5">Mã giao dịch</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.TransactionId) ? Model.TransactionId : "—")</dd>

                    <dt class="col-sm-5">Gateway OrderId</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.PaymentGatewayOrderId) ? Model.PaymentGatewayOrderId : "—")</dd>

                    <dt class="col-sm-5">Mã phản hồi</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.ResponseCode) ? Model.ResponseCode : "—")</dd>

                    <dt class="col-sm-5">Thông báo</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.ResponseMessage) ? Model.ResponseMessage : "—")</dd>

                    <dt class="col-sm-5">Loại thanh toán</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.PaymentType) ? Model.PaymentType : "—")</dd>

                    <dt class="col-sm-5">IP khách hàng</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.IpAddress) ? Model.IpAddress : "—")</dd>

                    <dt class="col-sm-5">Cập nhật cuối</dt>
                    <dd class="col-sm-7">@Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—"</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Thông tin đơn hàng</h5>
            </div>
            <div class="card-body">
                @if (order != null)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Khách hàng</dt>
                        <dd class="col-sm-7">@order.TenKhachHang</dd>

                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@order.Email</dd>

                        <dt class="col-sm-5">Số điện thoại</dt>
                        <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(order.SoDienThoai) ? order.SoDienThoai : "—")</dd>

                        <dt class="col-sm-5">Địa chỉ</dt>
                        <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(order.DiaChiGiaoHang) ? order.DiaChiGiaoHang : "—")</dd>

                        <dt class="col-sm-5">Trạng thái đơn</dt>
                        <dd class="col-sm-7">@order.TrangThai</dd>

                        <dt class="col-sm-5">Ngày đặt</dt>
                        <dd class="col-sm-7">@order.NgayDat.ToString("dd/MM/yyyy HH:mm")</dd>
                    </dl>
                }
                else
                {
                    <p class="text-muted mb-0">Không tìm thấy thông tin đơn hàng tương ứng.</p>
                }
            </div>
        </div>
    </div>
</div>

@if (order?.OrderDetails != null && order.OrderDetails.Any())
{
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Sản phẩm trong đơn</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Sách</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in order.OrderDetails)
                        {
                            <tr>
                                <td>@detail.Sach?.TenSach ?? $"Sách #{detail.MaSach}"</td>
                                <td>@detail.SoLuong</td>
                                <td>@detail.Gia.ToString("N0") đ</td>
                                <td>@(detail.SoLuong * detail.Gia).ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


