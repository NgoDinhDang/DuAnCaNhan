@model STOREBOOKS.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title"><i class="fas fa-lock me-2"></i> Đặt lại mật khẩu</h2>
        <form asp-action="ResetPassword" method="post" class="auth-form">
            <input type="hidden" asp-for="Token" />
            <div class="form-group mb-3">
                <label class="form-label">Mật khẩu mới</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-unlock-alt"></i></span>
                    <input asp-for="Password" class="form-control" type="password" required placeholder="Nhập mật khẩu mới" />
                </div>
            </div>
            <div class="form-group mb-4">
                <label class="form-label">Nhập lại mật khẩu</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" required placeholder="Xác nhận mật khẩu mới" />
                </div>
            </div>
            <button type="submit" class="btn btn-success auth-btn-gradient">Cập nhật mật khẩu</button>
        </form>
        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show custom-alert mt-3" role="alert">
                @ViewBag.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>
</div>