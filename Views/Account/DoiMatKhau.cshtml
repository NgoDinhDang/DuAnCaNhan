@model STOREBOOKS.ViewModels.DoiMatKhau
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title"><i class="fas fa-lock me-2"></i> Đổi mật khẩu</h2>
        @if (ViewBag.Message != null)
        {
            <div class="alert alert-success alert-dismissible fade show custom-alert" role="alert">
                @ViewBag.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.ThongBao != null)
        {
            <div class="alert alert-danger alert-dismissible fade show custom-alert" role="alert">
                @ViewBag.ThongBao
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form asp-action="DoiMatKhau" method="post" class="auth-form">
            <div class="form-group mb-3">
                <label class="form-label">Mật khẩu cũ</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                    <input asp-for="MatKhauCu" class="form-control" type="password" placeholder="Nhập mật khẩu cũ" />
                </div>
                <span asp-validation-for="MatKhauCu" class="text-danger validation-message"></span>
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Mật khẩu mới</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-unlock-alt"></i></span>
                    <input asp-for="MatKhauMoi" class="form-control" type="password" placeholder="Tạo mật khẩu mới" />
                </div>
                <span asp-validation-for="MatKhauMoi" class="text-danger validation-message"></span>
            </div>
            <div class="form-group mb-4">
                <label class="form-label">Xác nhận mật khẩu mới</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                    <input asp-for="XacNhanMatKhauMoi" class="form-control" type="password" placeholder="Xác nhận mật khẩu mới" />
                </div>
                <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger validation-message"></span>
            </div>
            <button type="submit" class="btn btn-primary auth-btn-gradient">Đổi mật khẩu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}