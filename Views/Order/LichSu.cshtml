@model IEnumerable<STOREBOOKS.Models.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<!-- Header Section -->
<div class="order-history-header">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="header-content">
                    <div class="header-icon">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                    <div class="header-text">
                        <h1 class="header-title">Lịch sử đơn hàng</h1>
                        <p class="header-subtitle">Theo dõi và quản lý tất cả đơn hàng của bạn</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/" class="btn-continue-shopping">
                    <i class="fas fa-arrow-left me-2"></i>
                    Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid py-5">
    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="empty-orders">
            <div class="empty-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <h3 class="empty-title">Bạn chưa có đơn hàng nào</h3>
            <p class="empty-description">
                Hãy bắt đầu hành trình mua sắm với chúng tôi để khám phá những cuốn sách tuyệt vời!
            </p>
            <div class="empty-actions">
                <a href="/" class="btn-primary-shop">
                    <i class="fas fa-store me-2"></i>
                    Khám phá cửa hàng
                </a>
                <a href="/Books" class="btn-secondary-books">
                    <i class="fas fa-book me-2"></i>
                    Xem danh sách sách
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Orders Summary -->
        <div class="orders-summary mb-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="summary-card total-orders">
                        <div class="card-icon">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                        <div class="card-content">
                            <h4 class="card-value">@Model.Count()</h4>
                            <p class="card-label">Tổng đơn hàng</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-card completed-orders">
                        <div class="card-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <div class="card-content">
                            <h4 class="card-value">@Model.Count(o => o.TrangThai == "Đã giao")</h4>
                            <p class="card-label">Đã hoàn thành</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-card pending-orders">
                        <div class="card-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="card-content">
                            <h4 class="card-value">@Model.Count(o => o.TrangThai == "Chờ xác nhận" || o.TrangThai == "Đang giao")</h4>
                            <p class="card-label">Đang xử lý</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-card total-spent">
                        <div class="card-icon">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <div class="card-content">
                            <h4 class="card-value">@Model.Sum(o => o.TongTien).ToString("N0") đ</h4>
                            <p class="card-label">Tổng chi tiêu</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders List -->
        <div class="orders-container">
            @foreach (var item in Model.OrderByDescending(o => o.NgayDat))
            {
                var statusClass = item.TrangThai.Replace(" ", "-").ToLower();
                var canCancel = item.TrangThai == "Chờ xác nhận";
                var isCancelled = item.TrangThai == "Đã hủy";

                <div class="order-card @(isCancelled ? "cancelled" : "")">
                    <div class="order-header">
                        <div class="order-info">
                            <div class="order-id">
                                <span class="order-label">Đơn hàng</span>
                                <span class="order-number">#@item.OrderId</span>
                            </div>
                            <div class="order-date">
                                <i class="fas fa-calendar-alt"></i>
                                @item.NgayDat.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="order-status">
                            <span class="status-badge status-@statusClass">
                                @item.TrangThai
                            </span>
                        </div>
                    </div>

                    <div class="order-body">
                        <div class="order-details">
                            <div class="detail-item">
                                <span class="detail-label">Tổng tiền:</span>
                                <span class="detail-value">@item.TongTien.ToString("N0") đ</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Người nhận:</span>
                                <span class="detail-value">@item.TenKhachHang</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">SĐT:</span>
                                <span class="detail-value">@item.SoDienThoai</span>
                            </div>
                        </div>

                        <div class="order-actions">
                            <a href="/Order/ChiTietDonMua/@item.OrderId" class="btn-view-order" title="Xem chi tiết đơn hàng">
                                <i class="fas fa-eye me-2"></i>
                                Xem chi tiết
                            </a>
                            @if (canCancel)
                            {
                                <button class="btn-cancel-order" onclick="cancelOrder(@item.OrderId)">
                                    <i class="fas fa-times me-2"></i>
                                    Hủy đơn
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* ===== ORDER HISTORY HEADER ===== */
    .order-history-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 3rem 0;
        margin-bottom: 2rem;
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        backdrop-filter: blur(10px);
    }

    .header-title {
        font-size: 2.25rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(45deg, #ffffff, rgba(255,255,255,0.8));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .header-subtitle {
        font-size: 1.1rem;
        margin: 0.5rem 0 0 0;
        opacity: 0.9;
    }

    .btn-continue-shopping {
        display: inline-flex;
        align-items: center;
        padding: 0.875rem 2rem;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .btn-continue-shopping:hover {
        background: white;
        color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }

    /* ===== EMPTY STATE ===== */
    .empty-orders {
        text-align: center;
        padding: 3rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        margin: 2rem auto;
        max-width: 600px;
    }

    .empty-icon {
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.25rem;
        color: white;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 25px rgba(245, 87, 108, 0.3);
    }

    .empty-title {
        font-size: 2rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 1rem;
    }

    .empty-description {
        font-size: 1.1rem;
        color: #718096;
        margin-bottom: 2.5rem;
        line-height: 1.6;
    }

    .empty-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary-shop {
        display: inline-flex;
        align-items: center;
        padding: 0.875rem 1.75rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-primary-shop:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
    }

    .btn-secondary-books {
        display: inline-flex;
        align-items: center;
        padding: 0.875rem 1.75rem;
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .btn-secondary-books:hover {
        background: #667eea;
        color: white;
        transform: translateY(-3px);
    }

    /* ===== ORDERS SUMMARY ===== */
    .orders-summary {
        margin-bottom: 3rem;
    }

    .summary-card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        gap: 1.25rem;
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.8);
    }

    .summary-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    }

    .card-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .total-orders .card-icon {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .completed-orders .card-icon {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
        color: white;
    }

    .pending-orders .card-icon {
        background: linear-gradient(135deg, #ed8936 0%, #dd6b20 100%);
        color: white;
    }

    .total-spent .card-icon {
        background: linear-gradient(135deg, #9f7aea 0%, #805ad5 100%);
        color: white;
    }

    .card-content {
        flex: 1;
    }

    .card-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #2d3748;
        margin: 0;
        line-height: 1.2;
    }

    .card-label {
        color: #718096;
        font-size: 0.9rem;
        margin: 0.25rem 0 0 0;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ===== ORDERS CONTAINER ===== */
    .orders-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .order-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.8);
    }

    .order-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }

    .order-card.cancelled {
        opacity: 0.7;
        border-color: #fc8181;
    }

    .order-header {
        background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
        padding: 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e2e8f0;
    }

    .order-info {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .order-id .order-label {
        display: block;
        color: #718096;
        font-size: 0.875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .order-id .order-number {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2d3748;
    }

    .order-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #718096;
        font-size: 0.9rem;
    }

    .order-date i {
        color: #a0aec0;
    }

    .order-status {
        flex-shrink: 0;
    }

    .order-body {
        padding: 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-details {
        display: flex;
        gap: 1.5rem;
        flex: 1;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .detail-label {
        color: #718096;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .detail-value {
        color: #2d3748;
        font-weight: 600;
        font-size: 1rem;
    }

    .order-details .detail-value {
        color: #38a169;
        font-size: 1.125rem;
    }

    .order-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .btn-view-order {
        display: inline-flex;
        align-items: center;
        padding: 0.625rem 1.25rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
    }

    .btn-view-order:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-cancel-order {
        display: inline-flex;
        align-items: center;
        padding: 0.625rem 1.25rem;
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(245, 101, 101, 0.3);
    }

    .btn-cancel-order:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 101, 101, 0.4);
    }

    /* ===== STATUS BADGES ===== */
    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .status-cho-xac-nhan {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
    }

    .status-dang-giao {
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        color: white;
    }

    .status-da-giao {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
    }

    .status-da-huy {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
    }

    /* ===== RESPONSIVE DESIGN ===== */
    @@media (max-width: 768px) {
        .order-history-header {
            padding: 2rem 0;
        }

        .header-content {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }

        .header-title {
            font-size: 1.875rem;
        }

        .header-icon {
            width: 50px;
            height: 50px;
            font-size: 1.25rem;
        }

        .btn-continue-shopping {
            margin-top: 1rem;
        }

        .orders-summary .col-md-3 {
            margin-bottom: 1rem;
        }

        .summary-card {
            padding: 1.25rem;
            gap: 1rem;
        }

        .card-icon {
            width: 45px;
            height: 45px;
            font-size: 1.125rem;
        }

        .card-value {
            font-size: 1.5rem;
        }

        .order-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
            padding: 1rem;
        }

        .order-info {
            flex-direction: column;
            gap: 0.5rem;
        }

        .order-body {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
            padding: 1rem;
        }

        .order-details {
            flex-direction: column;
            gap: 1rem;
        }

        .order-actions {
            justify-content: center;
        }

        .empty-actions {
            flex-direction: column;
        }

        .empty-orders {
            padding: 2.5rem 1rem;
        }

        .empty-title {
            font-size: 1.375rem;
        }

        .empty-icon {
            width: 75px;
            height: 75px;
            font-size: 1.875rem;
        }
    }

    @@media (max-width: 576px) {
        .header-title {
            font-size: 1.625rem;
        }

        .card-value {
            font-size: 1.375rem;
        }

        .order-id .order-number {
            font-size: 1.125rem;
        }

        .detail-value {
            font-size: 0.875rem;
        }

        .summary-card {
            padding: 1rem;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    async function cancelOrder(orderId) {
        const result = await Swal.fire({
            title: 'Xác nhận hủy đơn hàng?',
            text: 'Bạn có chắc chắn muốn hủy đơn hàng này không? Hành động này không thể hoàn tác.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Có, hủy đơn!',
            cancelButtonText: 'Không'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch('/Order/HuyDonHang', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: `id=${orderId}`
                });

                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Đã hủy đơn hàng!',
                        text: data.message,
                        confirmButtonColor: '#28a745'
                    });

                    // Reload trang để cập nhật trạng thái
                    location.reload();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi!',
                        text: data.message,
                        confirmButtonColor: '#dc3545'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi!',
                    text: 'Có lỗi xảy ra khi hủy đơn hàng',
                    confirmButtonColor: '#dc3545'
                });
            }
        }
    }
</script>

@* Anti-forgery token for AJAX requests *@
<form id="__AjaxAntiForgeryForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>