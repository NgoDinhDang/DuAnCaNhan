@model string
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title"><i class="fas fa-key me-2"></i> Quên mật khẩu</h2>
        <form asp-action="ForgotPassword" method="post" class="auth-form">
            <div class="form-group mb-4">
                <label class="form-label"><i class="fas fa-envelope me-1"></i> Nhập Email của bạn</label>
                <div class="input-group auth-input-group">
                    <span class="input-group-text"><i class="fas fa-at"></i></span>
                    <input type="email" name="email" class="form-control" required placeholder="abc@example.com" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary auth-btn-gradient">Gửi liên kết đặt lại mật khẩu</button>
        </form>
        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show custom-alert mt-3" role="alert">
                @Html.Raw(ViewBag.Message)
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>
</div>