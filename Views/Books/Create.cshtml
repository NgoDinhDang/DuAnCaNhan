@inject IHttpContextAccessor HttpContextAccessor
@model STOREBOOKS.Models.Sach

@{
    ViewData["Title"] = "Thêm sách mới";
    var isAdmin = HttpContextAccessor.HttpContext.Session.GetString("VaiTro") == "Admin";
}

@if (isAdmin)
{
    <div class="admin-page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="admin-page-title">
                    <i class="fas fa-plus me-2"></i>
                    Thêm sách mới
                </h2>
                <p class="admin-page-subtitle">Thêm cuốn sách mới vào hệ thống</p>
            </div>
            <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-sm">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <partial name="_AdminNav" />
}

<div class="container mt-5">
    @if (!isAdmin)
    {
        <h2 class="book-list-title"><i class="fas fa-plus me-2"></i> Thêm sách mới</h2>
    }
    <div class="card p-4 shadow rounded-4">

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="alert alert-danger">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="form-group mb-3">
                <label asp-for="TenSach" class="form-label"><i class="fas fa-book me-1"></i> Tên sách</label>
                <input asp-for="TenSach" class="form-control rounded-pill" />
                <span asp-validation-for="TenSach" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TacGia" class="form-label"><i class="fas fa-user me-1"></i> Tác Giả</label>
                <input asp-for="TacGia" class="form-control rounded-pill" />
                <span asp-validation-for="TacGia" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Gia" class="form-label"><i class="fas fa-dollar-sign me-1"></i> Giá</label>
                <input asp-for="Gia" class="form-control rounded-pill" type="number" step="1000" />
                <span asp-validation-for="Gia" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="GiamGia" class="form-label"><i class="fas fa-percentage me-1"></i> Giảm giá (%)</label>
                <input asp-for="GiamGia" class="form-control rounded-pill" type="number" min="0" max="100" />
                <span asp-validation-for="GiamGia" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MoTa" class="form-label"><i class="fas fa-align-left me-1"></i> Mô tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MaDanhMuc" class="form-label"><i class="fas fa-list me-1"></i> Danh mục</label>
                <select asp-for="MaDanhMuc" class="form-select rounded-pill" asp-items="ViewBag.DanhMuc">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label"><i class="fas fa-upload me-1"></i> Hình ảnh</label>
                <input type="file" name="HinhAnhFile" class="form-control rounded-pill" />
            </div>

            <div class="form-check form-switch mb-3">
                <input asp-for="IsKhuyenMai" class="form-check-input" type="checkbox" />
                <label asp-for="IsKhuyenMai" class="form-check-label"><i class="fas fa-gift me-1"></i> Sách khuyến mãi</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input asp-for="IsNoiBat" class="form-check-input" type="checkbox" />
                <label asp-for="IsNoiBat" class="form-check-label"><i class="fas fa-star me-1"></i> Sách nổi bật</label>
            </div>

            <div class="form-group mt-4 d-flex gap-2">
                <input type="submit" value="Thêm" class="btn btn-primary rounded-pill px-4" />
                <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
