@model STOREBOOKS.Models.Order
@{
    ViewData["Title"] = "Cập nhật trạng thái đơn hàng";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-edit me-2"></i>
                Cập nhật trạng thái đơn hàng #@Model.OrderId
            </h2>
            <p class="admin-page-subtitle">Thay đổi trạng thái của đơn hàng</p>
        </div>
        <a href="/admin/order" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container py-4">

    <div class="modern-card">
        <form action="/admin/order/capnhattrangthai" method="post" class="space-y-6">
            <input type="hidden" asp-for="OrderId" />
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="TrangThai" class="block font-semibold text-lg">Trạng thái mới:</label>
                <select name="trangThai" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 custom-select">
                    <option value="Chờ xác nhận" selected="@(Model.TrangThai == "Chờ xác nhận")">Chờ xác nhận</option>
                    <option value="Đang giao" selected="@(Model.TrangThai == "Đang giao")">Đang giao</option>
                    <option value="Đã giao" selected="@(Model.TrangThai == "Đã giao")">Đã giao</option>
                    <option value="Đã hủy" selected="@(Model.TrangThai == "Đã hủy")">Đã hủy</option>
                </select>
            </div>

            <div class="flex items-center space-x-4">
                <button type="submit" class="btn bg-blue-600 **text-white** px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300">Cập nhật</button>
                <a href="/admin/order" class="btn text-gray-600 hover:text-blue-600 hover:underline">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

<style>
    /* Custom style for select to mimic input look */
    .custom-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23333' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 0.75rem center;
        background-size: 0.8rem 0.5rem;
        padding-right: 2.5rem;
    }

    .h2-gradient {
        background: linear-gradient(45deg, #6a11cb, #2575fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        font-size: 2.5rem; /* Make it a bit bigger for impact */
        margin-bottom: 2rem;
    }

    .text-primary-color {
        color: #6a11cb; /* Ensure order ID stands out */
    }
</style>