@model STOREBOOKS.Models.DanhMuc

@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-plus me-2"></i>
                Thêm danh mục mới
            </h2>
            <p class="admin-page-subtitle">Tạo danh mục sách mới trong hệ thống</p>
        </div>
        <a href="/admin/danhmuc" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container form-card animate__animated animate__fadeInDown">

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
    {
        <div class="alert alert-danger validation-summary-errors animate__animated animate__shakeX" role="alert">
            <h5 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i> Có lỗi xảy ra!</h5>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form action="/admin/danhmuc/create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger validation-message"></div>
        <div class="form-group mb-3">
            <label asp-for="TenDanhMuc" class="control-label"><i class="fas fa-tag me-1"></i> Tên danh mục:</label>
            <input asp-for="TenDanhMuc" class="form-control" placeholder="Nhập tên danh mục..." />
            <span asp-validation-for="TenDanhMuc" class="text-danger validation-message"></span>
        </div>
        <div class="mt-4 d-flex justify-content-end gap-3">
            <button type="submit" class="btn btn-primary-gradient animate__animated animate__pulse animate__infinite"><i class="fas fa-plus-circle"></i> Thêm danh mục</button>
            <a href="/admin/danhmuc" class="btn btn-secondary-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}