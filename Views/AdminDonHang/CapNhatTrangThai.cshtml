@model STOREBOOKS.Models.Order
@{
    ViewData["Title"] = "Cập nhật trạng thái";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square"></i>
                Cập nhật trạng thái đơn hàng
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="CapNhatTrangThai" method="post">
                <input type="hidden" name="id" value="@Model.OrderId" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Mã đơn hàng:</label>
                    <p class="text-secondary mb-1">#@Model.OrderId</p>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Trạng thái hiện tại:</label>
                    <p>
                        <span class="badge bg-info p-2">
                            @Model.TrangThai
                        </span>
                    </p>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold" for="trangThai">
                        Trạng thái mới:
                    </label>

                    <select class="form-select p-2" name="trangThai" id="trangThai" required>
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="Chờ xác nhận">Chờ xác nhận</option>
                        <option value="Đang giao">Đang giao</option>
                        <option value="Hoàn tất">Hoàn tất</option>
                        <option value="Đã hủy">Đã hủy</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle"></i> Cập nhật
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>
