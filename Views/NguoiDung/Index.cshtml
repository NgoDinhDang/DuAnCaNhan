@model IEnumerable<STOREBOOKS.Models.NguoiDung>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var currentPage = ViewBag.CurrentPage ?? 1;
    var pageSize = ViewBag.PageSize ?? 10;
    var totalItems = ViewBag.TotalItems ?? 0;
    var totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
    var keyword = ViewBag.Keyword as string;
    var roleFilter = ViewBag.RoleFilter as string;
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-users me-2"></i>
                Quản lý người dùng
            </h2>
            <p class="admin-page-subtitle">Quản lý tài khoản người dùng và phân quyền</p>
        </div>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="/admin/nguoidung/thongke" class="btn btn-outline-info me-2 rounded-pill"><i class="fas fa-chart-bar"></i> Thống kê</a>
            <a href="/admin/nguoidung/create" class="btn btn-success rounded-pill"><i class="fas fa-user-plus"></i> Thêm</a>
        </div>
    </div>

    <form method="get" class="row mb-3 g-2">
        <div class="col-md-4">
            <input type="text" name="keyword" class="form-control" placeholder="Tìm tên hoặc email..." value="@keyword" />
        </div>
        <div class="col-md-3">
            <select name="roleFilter" class="form-select">
                <option value="">-- Tất cả vai trò --</option>
                <option value="Admin" selected="@("Admin" == roleFilter)">Admin</option>
                <option value="User" selected="@("User" == roleFilter)">User</option>
                <option value="Blocked" selected="@("Blocked" == roleFilter)">Blocked</option>
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-primary" type="submit"><i class="fas fa-filter"></i> Lọc</button>
        </div>
    </form>

    <table class="table table-bordered table-hover bg-white shadow-sm">
        <thead class="bg-primary text-white">
            <tr>
                <th>Tên đăng nhập</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TaiKhoan?.TenDangNhap</td>
                    <td>@item.TaiKhoan?.Email</td>
                    <td>
                        @{
                            var role = item.TaiKhoan?.VaiTro ?? "User";
                        }
                        <span class="badge @(role == "Admin" ? "bg-danger" : role == "Blocked" ? "bg-dark" : "bg-secondary")">
                            @role
                        </span>
                    </td>
                    <td>
                        @if ((item.TaiKhoan?.VaiTro ?? "") == "Blocked")
                        {
                            <span class="text-danger fw-bold">Bị chặn</span>
                        }
                        else
                        {
                            <span class="text-success">Hoạt động</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a href="/admin/nguoidung/details/@item.MaNguoiDung" class="btn btn-sm btn-info text-white rounded-pill"><i class="fas fa-eye"></i></a>
                            <a href="/admin/nguoidung/edit/@item.MaNguoiDung" class="btn btn-sm btn-warning text-white rounded-pill"><i class="fas fa-edit"></i></a>

                            <button type="button" class="btn btn-sm btn-danger rounded-pill" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-user-id="@item.MaNguoiDung" data-username="@item.TaiKhoan?.TenDangNhap">
                                <i class="fas fa-trash-alt"></i>
                            </button>

                            @if ((item.TaiKhoan?.VaiTro ?? "") != "Blocked")
                            {
                                <button type="button" class="btn btn-sm btn-outline-dark rounded-pill" data-bs-toggle="modal" data-bs-target="#confirmBlockModal" data-user-id="@item.MaNguoiDung" data-username="@item.TaiKhoan?.TenDangNhap">
                                    <i class="fas fa-user-slash"></i>
                                </button>
                            }

                            <a href="/admin/nguoidung/phanquyen/@item.MaNguoiDung" class="btn btn-sm btn-outline-primary rounded-pill"><i class="fas fa-user-cog"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="/admin/nguoidung?page=@i&keyword=@keyword&roleFilter=@roleFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/admin/nguoidung/delete">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteUserId" />
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Xác nhận xóa</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Bạn có chắc chắn muốn xóa người dùng <strong id="deleteUserName"></strong>?
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="confirmBlockModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/admin/nguoidung/channguoidung">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="blockUserId" />
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Xác nhận chặn</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Bạn có muốn <strong>chặn</strong> người dùng <strong id="blockUserName"></strong>?
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-dark">Chặn</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('confirmDeleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var userId = button.getAttribute('data-user-id');
            var username = button.getAttribute('data-username');
            document.getElementById('deleteUserId').value = userId;
            document.getElementById('deleteUserName').textContent = username;
        });

        var blockModal = document.getElementById('confirmBlockModal');
        blockModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var userId = button.getAttribute('data-user-id');
            var username = button.getAttribute('data-username');
            document.getElementById('blockUserId').value = userId;
            document.getElementById('blockUserName').textContent = username;
        });
    </script>
}