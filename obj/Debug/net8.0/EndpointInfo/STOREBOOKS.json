{
  "openapi": "3.0.1",
  "info": {
    "title": "STOREBOOKS API",
    "description": "API Documentation cho hệ thống bán sách trực tuyến STOREBOOKS",
    "contact": {
      "name": "STOREBOOKS Development Team",
      "email": "support@storebooks.com"
    },
    "version": "v1"
