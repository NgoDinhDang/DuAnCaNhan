@model STOREBOOKS.Models.DanhMuc

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-trash-alt me-2"></i>
                Xóa danh mục
            </h2>
            <p class="admin-page-subtitle">Xác nhận xóa danh mục khỏi hệ thống</p>
        </div>
        <a href="/admin/danhmuc" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container delete-confirmation-card animate__animated animate__zoomIn">

    <h4 class="mb-3">Bạn có chắc muốn xóa danh mục này?</h4>
    <p>
        <strong class="text-gradient-main">@Model.TenDanhMuc</strong>
    </p>

    <div class="alert alert-warning custom-alert animate__animated animate__fadeIn" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        Hành động này không thể hoàn tác!
    </div>

    <form action="/admin/danhmuc/delete/@Model.MaDanhMuc" method="post" class="mt-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MaDanhMuc" />
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-delete animate__animated animate__pulse animate__infinite"><i class="fas fa-trash-alt"></i> Xác nhận xóa</button>
            <a href="/admin/danhmuc" class="btn btn-secondary-outline"><i class="fas fa-times-circle"></i> Hủy bỏ</a>
        </div>
    </form>
</div>