@model STOREBOOKS.Models.NguoiDung
@{
    ViewData["Title"] = "Xóa người dùng";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-user-times me-2"></i>
                Xóa người dùng
            </h2>
            <p class="admin-page-subtitle">Xác nhận xóa tài khoản người dùng khỏi hệ thống</p>
        </div>
        <a href="/admin/nguoidung" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container mt-4">
    <div class="card shadow p-4 rounded-4 border-danger">

        <div class="alert alert-warning">
            <strong>Bạn có chắc chắn muốn xóa người dùng sau không?</strong>
        </div>

        <dl class="row">
            <dt class="col-sm-3 fw-semibold">Tên đăng nhập:</dt>
            <dd class="col-sm-9">@Model.TaiKhoan?.TenDangNhap</dd>

            <dt class="col-sm-3 fw-semibold">Email:</dt>
            <dd class="col-sm-9">@Model.TaiKhoan?.Email</dd>

            <dt class="col-sm-3 fw-semibold">Vai trò:</dt>
            <dd class="col-sm-9">@Model.TaiKhoan?.VaiTro</dd>
        </dl>

        <form action="/admin/nguoidung/delete/@Model.MaNguoiDung" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MaNguoiDung" />
            <div class="mt-4 d-flex justify-content-between">
                <a href="/admin/nguoidung" class="btn btn-secondary rounded-pill px-4">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-danger rounded-pill px-4">
                    <i class="fas fa-trash-alt"></i> Xóa người dùng
                </button>
            </div>
        </form>
    </div>
</div>