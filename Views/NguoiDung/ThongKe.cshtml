@{
    ViewData["Title"] = "Thống kê người dùng";
    var tongNguoiDung = ViewBag.TongNguoiDung ?? 0;
    var soAdmin = ViewBag.SoAdmin ?? 0;
    var soUser = ViewBag.SoUser ?? 0;
    var soBiChan = ViewBag.SoBiChan ?? 0;
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="admin-page-title">
                <i class="fas fa-chart-bar me-2"></i>
                Thống kê người dùng
            </h2>
            <p class="admin-page-subtitle">Thống kê và phân tích người dùng trong hệ thống</p>
        </div>
        <a href="/admin/nguoidung" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<partial name="_AdminNav" />

<div class="container mt-4">

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title">Tổng người dùng</h5>
                    <p class="display-6 fw-bold">@tongNguoiDung</p>
                    <i class="fas fa-users fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title">Admin</h5>
                    <p class="display-6 fw-bold">@soAdmin</p>
                    <i class="fas fa-user-shield fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title">User</h5>
                    <p class="display-6 fw-bold">@soUser</p>
                    <i class="fas fa-user fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-dark shadow-sm rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title">Bị chặn</h5>
                    <p class="display-6 fw-bold">@soBiChan</p>
                    <i class="fas fa-user-slash fa-2x"></i>
                </div>
            </div>
        </div>
    </div>
</div>