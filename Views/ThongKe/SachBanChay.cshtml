@{
    ViewData["Title"] = "Thống kê sách bán chạy & Lượt xem";
    var topBanChay = ViewBag.TopBanChay as List<dynamic>;
    var topXemNhieu = ViewBag.TopXemNhieu as List<dynamic>;
    var tongSoLuotXem = ViewBag.TongSoLuotXem;
    var tongSoLuongBan = ViewBag.TongSoLuongBan;
    var tongDoanhThu = ViewBag.TongDoanhThu;
    var tyLeChuyenDoiTrungBinh = ViewBag.TyLeChuyenDoiTrungBinh;
}

<style>
    .stats-page {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .stats-header {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        animation: slideDown 0.5s ease-out;
    }

    @@keyframes slideDown {
        from { transform: translateY(-30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .stats-title {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
    }

    .stats-subtitle {
        color: #6c757d;
        font-size: 1.1rem;
    }

    /* Summary Cards */
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .summary-card {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        animation: fadeInUp 0.5s ease-out;
        animation-fill-mode: both;
    }

    .summary-section .summary-card:nth-child(1) { animation-delay: 0.1s; }
    .summary-section .summary-card:nth-child(2) { animation-delay: 0.2s; }
    .summary-section .summary-card:nth-child(3) { animation-delay: 0.3s; }
    .summary-section .summary-card:nth-child(4) { animation-delay: 0.4s; }

    @@keyframes fadeInUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .summary-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .summary-card-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1rem;
    }

    .summary-card-icon.views {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .summary-card-icon.sales {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .summary-card-icon.revenue {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
    }

    .summary-card-icon.conversion {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        color: white;
    }

    .summary-card-label {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 0.5rem;
    }

    .summary-card-value {
        font-size: 2rem;
        font-weight: 700;
        color: #2d3748;
    }

    .summary-card-desc {
        font-size: 0.85rem;
        color: #a0aec0;
        margin-top: 0.25rem;
    }

    /* Summary Section */
    .summary-section {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 2px solid #e9ecef;
    }

    .summary-section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    /* Tabs */
    .stats-tabs {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .nav-tabs-modern {
        border: none;
        gap: 1rem;
    }

    .nav-tabs-modern .nav-link {
        border: none;
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        color: #6c757d;
        font-weight: 600;
        transition: all 0.3s ease;
        background: #f8f9fa;
    }

    .nav-tabs-modern .nav-link:hover {
        background: #e9ecef;
        color: #495057;
    }

    .nav-tabs-modern .nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    /* Table */
    .stats-table-container {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        overflow-x: auto;
    }

    .stats-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .stats-table thead th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        font-weight: 600;
        text-align: left;
        border: none;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .stats-table thead th:first-child {
        border-top-left-radius: 10px;
    }

    .stats-table thead th:last-child {
        border-top-right-radius: 10px;
    }

    .stats-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #e9ecef;
    }

    .stats-table tbody tr:hover {
        background: #f8f9fa;
        transform: scale(1.01);
    }

    .stats-table tbody td {
        padding: 1rem;
        vertical-align: middle;
    }

    .book-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .book-image {
        width: 60px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    .book-details {
        flex: 1;
    }

    .book-title {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.25rem;
    }

    .book-author {
        font-size: 0.85rem;
        color: #6c757d;
    }

    .badge-modern {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .badge-sales {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .badge-views {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .badge-revenue {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
    }

    .badge-conversion {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        color: white;
    }

    .ranking-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        font-weight: 700;
        font-size: 1rem;
    }

    .ranking-badge.top-1 {
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        color: #995700;
        box-shadow: 0 4px 10px rgba(255, 215, 0, 0.4);
    }

    .ranking-badge.top-2 {
        background: linear-gradient(135deg, #c0c0c0 0%, #e8e8e8 100%);
        color: #555;
        box-shadow: 0 4px 10px rgba(192, 192, 192, 0.4);
    }

    .ranking-badge.top-3 {
        background: linear-gradient(135deg, #cd7f32 0%, #e89c5c 100%);
        color: #6b3e1a;
        box-shadow: 0 4px 10px rgba(205, 127, 50, 0.4);
    }

    .ranking-badge.other {
        background: #f8f9fa;
        color: #6c757d;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .stats-title {
            font-size: 1.8rem;
        }

        .summary-cards {
            grid-template-columns: 1fr;
        }

        .book-info {
            flex-direction: column;
            text-align: center;
        }

        .stats-table {
            font-size: 0.85rem;
        }
    }

    /* Chart container */
    .chart-container {
        background: white;
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .chart-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 1.5rem;
    }
</style>

<div class="stats-page">
    <div class="container">
        <!-- Header -->
        <div class="stats-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="stats-title">
                        <i class="fas fa-chart-bar me-2"></i>
                        Thống kê sách bán chạy & Lượt xem
                    </h1>
                    <p class="stats-subtitle">Phân tích hiệu suất bán hàng và lượt truy cập chi tiết</p>
                </div>
                <a href="/admin/thongke" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>
                    Quay lại
                </a>
            </div>
        </div>

        <partial name="_AdminNav" />

        <!-- Tabs -->
        <div class="stats-tabs">
            <ul class="nav nav-tabs nav-tabs-modern" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#top-sellers" type="button">
                        <i class="fas fa-fire me-2"></i>
                        Top sách bán chạy
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#top-views" type="button">
                        <i class="fas fa-eye me-2"></i>
                        Top sách được xem nhiều
                    </button>
                </li>
            </ul>
        </div>

        <!-- Tab Content -->
        <div class="tab-content">
            <!-- Top Sellers Tab -->
            <div class="tab-pane fade show active" id="top-sellers">
                <div class="stats-table-container">
                    <h3 class="chart-title">
                        <i class="fas fa-trophy text-warning me-2"></i>
                        Top 20 Sách Bán Chạy Nhất
                    </h3>
                    <table class="stats-table">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Hạng</th>
                                <th>Sách</th>
                                <th>Danh mục</th>
                                <th style="text-align: center;">Đã bán</th>
                                <th style="text-align: center;">Lượt xem</th>
                                <th style="text-align: right;">Doanh thu</th>
                                <th style="text-align: center;">Tỷ lệ chuyển đổi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topBanChay != null && topBanChay.Count > 0)
                            {
                                for (int i = 0; i < topBanChay.Count; i++)
                                {
                                    var item = topBanChay[i];
                                    string rankClass = i == 0 ? "top-1" : (i == 1 ? "top-2" : (i == 2 ? "top-3" : "other"));
                                    <tr>
                                        <td>
                                            <span class="ranking-badge @rankClass">@(i + 1)</span>
                                        </td>
                                        <td>
                                            <div class="book-info">
                                                @if (!string.IsNullOrEmpty(item.HinhAnh))
                                                {
                                                    <img src="~/images/@item.HinhAnh" alt="@item.TenSach" class="book-image" />
                                                }
                                                else
                                                {
                                                    <div class="book-image" style="background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                                                        <i class="fas fa-book" style="color: #6c757d;"></i>
                                                    </div>
                                                }
                                                <div class="book-details">
                                                    <div class="book-title">@item.TenSach</div>
                                                    <div class="book-author">@item.TacGia</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@item.DanhMuc</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="badge-modern badge-sales">@item.TongSoLuongBan</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="badge-modern badge-views">@item.SoLuotXem</span>
                                        </td>
                                        <td style="text-align: right;">
                                            <span class="badge-modern badge-revenue">@item.DoanhThu.ToString("N0") đ</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="badge-modern badge-conversion">@item.TyLeChuyenDoi%</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 3rem; color: #6c757d;">
                                        <i class="fas fa-inbox fa-3x mb-3" style="opacity: 0.3;"></i>
                                        <p>Chưa có dữ liệu thống kê</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Top Views Tab -->
            <div class="tab-pane fade" id="top-views">
                <div class="stats-table-container">
                    <h3 class="chart-title">
                        <i class="fas fa-eye text-primary me-2"></i>
                        Top 20 Sách Được Xem Nhiều Nhất
                    </h3>
                    <table class="stats-table">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Hạng</th>
                                <th>Sách</th>
                                <th>Danh mục</th>
                                <th style="text-align: center;">Lượt xem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topXemNhieu != null && topXemNhieu.Count > 0)
                            {
                                for (int i = 0; i < topXemNhieu.Count; i++)
                                {
                                    var item = topXemNhieu[i];
                                    string rankClass = i == 0 ? "top-1" : (i == 1 ? "top-2" : (i == 2 ? "top-3" : "other"));
                                    <tr>
                                        <td>
                                            <span class="ranking-badge @rankClass">@(i + 1)</span>
                                        </td>
                                        <td>
                                            <div class="book-info">
                                                @if (!string.IsNullOrEmpty(item.HinhAnh))
                                                {
                                                    <img src="~/images/@item.HinhAnh" alt="@item.TenSach" class="book-image" />
                                                }
                                                else
                                                {
                                                    <div class="book-image" style="background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                                                        <i class="fas fa-book" style="color: #6c757d;"></i>
                                                    </div>
                                                }
                                                <div class="book-details">
                                                    <div class="book-title">@item.TenSach</div>
                                                    <div class="book-author">@item.TacGia</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@item.DanhMuc</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="badge-modern badge-views">@item.SoLuotXem</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align: center; padding: 3rem; color: #6c757d;">
                                        <i class="fas fa-inbox fa-3x mb-3" style="opacity: 0.3;"></i>
                                        <p>Chưa có dữ liệu thống kê</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Summary Cards ở dưới -->
        <div class="summary-section">
            <h3 class="summary-section-title">
                <i class="fas fa-chart-pie me-2"></i>
                Thống kê tổng quan
            </h3>
            <div class="summary-cards">
                <div class="summary-card">
                    <div class="summary-card-icon views">
                        <i class="fas fa-eye"></i>
                    </div>
                    <div class="summary-card-label">Tổng lượt xem</div>
                    <div class="summary-card-value">@tongSoLuotXem.ToString("N0")</div>
                    <div class="summary-card-desc">Tất cả các sách</div>
                </div>

                <div class="summary-card">
                    <div class="summary-card-icon sales">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <div class="summary-card-label">Tổng sách đã bán</div>
                    <div class="summary-card-value">@tongSoLuongBan.ToString("N0")</div>
                    <div class="summary-card-desc">Đơn hàng hoàn tất</div>
                </div>

                <div class="summary-card">
                    <div class="summary-card-icon revenue">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div class="summary-card-label">Tổng doanh thu</div>
                    <div class="summary-card-value">@tongDoanhThu.ToString("N0") đ</div>
                    <div class="summary-card-desc">Từ các đơn hàng</div>
                </div>

                <div class="summary-card">
                    <div class="summary-card-icon conversion">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="summary-card-label">Tỷ lệ chuyển đổi</div>
                    <div class="summary-card-value">@tyLeChuyenDoiTrungBinh%</div>
                    <div class="summary-card-desc">Xem → Mua hàng</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add smooth animations
        document.addEventListener('DOMContentLoaded', () => {
            // Tab switch animation
            const tabButtons = document.querySelectorAll('[data-bs-toggle="tab"]');
            tabButtons.forEach(button => {
                button.addEventListener('shown.bs.tab', (e) => {
                    const target = document.querySelector(e.target.getAttribute('data-bs-target'));
                    target.style.animation = 'fadeInUp 0.5s ease-out';
                    setTimeout(() => {
                        target.style.animation = '';
                    }, 500);
                });
            });
        });
    </script>
}

