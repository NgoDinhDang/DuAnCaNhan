    "/api/ApiOrder/List": {
      "get": {
        "tags": [
          "ApiOrder"
        ],
        "summary": "Lấy danh sách đơn hàng với phân trang và lọc",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Lọc theo trạng thái đơn hàng (ví dụ: \"Chờ xác nhận\", \"Đã thanh toán\")",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDate",
            "in": "query",
            "description": "Lọc từ ngày (format: yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "toDate",
            "in": "query",
            "description": "Lọc đến ngày (format: yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Số trang (mặc định: 1)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Số lượng item mỗi trang (mặc định: 20)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trả về danh sách đơn hàng"
          },
          "401": {
            "description": "Chưa đăng nhập",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
